    {
      "parameters": {
        "jsCode": "const agora = new Date();\nconst ticketsAtrasados = [];\n\nfor (const item of $input.all()) {\n  const ticket = item.json;\n  \n  if (ticket.Status !== 'Aberto') continue;\n  \n  // Separa \"25/03/2026, 21:29\" em data e hora\n  const [dataParte, horaParte] = ticket.Data_Hora.split(', ');\n  const [dia, mes, ano] = dataParte.split('/');\n  const [hora, minuto] = horaParte.split(':');\n  \n  // Cria a data em UTC-3 (Brasília)\n  const dataTicket = new Date(Date.UTC(ano, mes - 1, dia, parseInt(hora) + 3, minuto));\n  \n  const horasPassadas = (agora - dataTicket) / (1000 * 60 * 60);\n  \n  let limiteHoras;\n  if (ticket.Urgencia === 'alta') limiteHoras = 2;\n  else if (ticket.Urgencia === 'media') limiteHoras = 4;\n  else limiteHoras = 24;\n  \n  if (horasPassadas > limiteHoras) {\n    ticketsAtrasados.push({\n      json: {\n        ...ticket,\n        horas_em_aberto: Math.round(horasPassadas),\n        limite_horas: limiteHoras\n      }\n    });\n  }\n}\n\nreturn ticketsAtrasados.length > 0 ? ticketsAtrasados : [{ json: { sem_atraso: true } }];"
      },
