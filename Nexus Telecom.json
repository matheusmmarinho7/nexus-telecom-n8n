    {
      "parameters": {
        "jsCode": "const emailOriginal = $('Gmail Trigger').first().json;\n\nconst fromRaw = emailOriginal.From || emailOriginal.from || '';\nconst fromString = typeof fromRaw === 'string' ? fromRaw : (fromRaw?.text || fromRaw?.value?.[0]?.address || JSON.stringify(fromRaw));\nconst fromClean = fromString.replace(/^From:\\s*/i, '').replace(/\"/g, '').trim();\n\ntry {\n  // Pega a resposta da IA (vem como texto)\n  const respostaIA = $input.first().json.output[0].content[0].text;\n  // Transforma o texto JSON em objeto JavaScript\n  const classificacao = JSON.parse(respostaIA);\n  // Gera um ID único para o ticket\n  const agora = new Date();\n  const timestamp = agora.getTime();\n  const idTicket = `TKT-${timestamp.toString().slice(-6)}`;\n  // Formata a data e hora no padrão brasileiro\n  const dataHora = agora.toLocaleString('pt-BR', {\n    timeZone: 'America/Sao_Paulo',\n    day: '2-digit', month: '2-digit', year: 'numeric',\n    hour: '2-digit', minute: '2-digit'\n  });\n  // Define o prazo de resposta baseado na urgência\n  let prazoResposta;\n  if (classificacao.urgencia === 'alta') {\n    prazoResposta = 'até 2 horas';\n  } else if (classificacao.urgencia === 'media') {\n    prazoResposta = 'até 4 horas';\n  } else {\n    prazoResposta = 'até 1 dia útil';\n  }\n  // Retorna todos os dados organizados para o próximo node\n  return [{\n    json: {\n      id_ticket: idTicket,\n      data_hora: dataHora,\n      remetente: fromClean,\n      email_cliente: fromClean.match(/<(.+)>/)?.[1] || fromClean,\n      assunto_original: emailOriginal['Subject'] || emailOriginal.subject || emailOriginal.snippet,\n      categoria: classificacao.categoria,\n      urgencia: classificacao.urgencia,\n      resumo_ia: classificacao.resumo,\n      nome_cliente: (() => {\n        if (classificacao.nome_cliente && classificacao.nome_cliente !== 'Cliente') {\n          return classificacao.nome_cliente;\n        }\n        const fromMatch = fromClean.match(/^([^<]+)</);\n        if (fromMatch) return fromMatch[1].trim().split(' ')[0];\n        return 'Cliente';\n      })(),\n      prazo_resposta: prazoResposta,\n      email_resposta: fromClean,\n      thread_id: emailOriginal.threadId,\n      sucesso: true\n    }\n  }];\n} catch (error) {\n  // OpenAI retornou algo inesperado — não quebra o fluxo\n  const agora = new Date();\n  const idTicket = `TKT-ERR-${agora.getTime().toString().slice(-6)}`;\n  const dataHora = agora.toLocaleString('pt-BR', {\n    timeZone: 'America/Sao_Paulo',\n    day: '2-digit', month: '2-digit', year: 'numeric',\n    hour: '2-digit', minute: '2-digit'\n  });\n  return [{\n    json: {\n      id_ticket: idTicket,\n      data_hora: dataHora,\n      remetente: fromClean,\n      assunto_original: emailOriginal['Subject'] || emailOriginal.subject || emailOriginal.snippet,\n      categoria: 'indefinido',\n      urgencia: 'media',\n      resumo_ia: 'Falha ao processar resposta da IA',\n      nome_cliente: '',\n      prazo_resposta: 'até 4 horas',\n      email_resposta: fromClean,\n      thread_id: emailOriginal.threadId,\n      sucesso: false,\n      erro: error.message\n    }\n  }];\n}"
      },
